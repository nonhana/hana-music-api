{
  "name": "hana-music-api",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --watch src/app/cli.ts",
    "start": "bun src/app/cli.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "postinstall": "bun docs:build",
    "test": "bun test",
    "test:phase5": "bun test tests/phase-5-regression.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:full": "oxlint src/",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check"
  },
  "dependencies": {
    "hono": "^4.12.10",
    "music-metadata": "^11.12.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4"
  }
}
