    "music-metadata": "^11.12.3",
    "qrcode": "^1.5.4",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
