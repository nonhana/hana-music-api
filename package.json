{
  "name": "hana-music-api",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run --watch src/app/cli.ts",
    "start": "bun run src/app/cli.ts",
    "migrate:modules": "bun run scripts/migrate-modules.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
