{
  "name": "hana-music-api",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run --watch src/app/cli.ts",
    "start": "bun run src/app/cli.ts",
    "docs:generate": "bun run scripts/generate-vitepress-docs.ts",
    "docs:dev": "bun run docs:generate && vitepress dev docs-site",
    "docs:build": "bun run docs:generate && vitepress build docs-site",
    "docs:preview": "bun run docs:build && vitepress preview docs-site",
    "migrate:modules": "bun run scripts/migrate-modules.ts",
    "test": "bun test",
    "test:phase5": "bun test tests/phase-5-regression.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:full": "oxlint src/",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "music-metadata": "^11.12.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4"
  }
}
